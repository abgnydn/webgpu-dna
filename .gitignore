.DS_Store

# E11 stages rad bins under public/ for vite to serve them to bench-chem.html.
# They are ~85 MB at 10 keV and regenerable from dumps/rad_E*_N4096.bin —
# never commit.
public/rad_E*_N*.bin

# Local editor/agent config
.claude/
.vscode/
.idea/

# Raw Geant4-DNA reference data (245 MB). Download from
# https://geant4-data.web.cern.ch/datasets/ and extract as data/g4emlow
# to regenerate public/cross_sections.wgsl via `npm run convert`.
data/

# Vercel / local tool caches
.vercel
.turbo
.wrangler/

# Demo + media artifacts (hosted out-of-repo to avoid bloat).
# wgdna-default.bin is fetched at runtime by the 4D viewer — fetch URL lives
# in src/splat/main.ts → loadBundledDemo().
public/wgdna-default.bin
splat.html.zip
demo_recording.webp
final_demo.webp

# Experiment IRT cache — recreatable from dumps/rad_E*_N4096.bin via run_irt.cjs.
experiments/.cache/

